<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <style>
    :root {
      --bg: #0f1419;
      --surface: #1a2332;
      --border: #2d3a4d;
      --text: #e6edf3;
      --muted: #8b949e;
      --accent: #3b82f6;
      --accent-hover: #2563eb;
      --success: #22c55e;
      --danger: #ef4444;
      --warning: #f59e0b;
    }
    * {
      box-sizing: border-box;
    }
    body {
      font-family: 'Segoe UI', system-ui, -apple-system, sans-serif;
      background: var(--bg);
      color: var(--text);
      margin: 0;
      min-height: 100vh;
      line-height: 1.5;
    }
    .container {
      max-width: 700px;
      margin: 0 auto;
      padding: 2rem 1.5rem;
    }
    h1 {
      font-size: 1.5rem;
      font-weight: 600;
      margin-bottom: 0.5rem;
    }
    .subtitle {
      color: var(--muted);
      font-size: 0.9rem;
      margin-bottom: 1.5rem;
    }
    .card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 12px;
      padding: 1.5rem;
      margin-bottom: 1.5rem;
    }
    .card h2 {
      font-size: 1.1rem;
      font-weight: 600;
      margin-top: 0;
      margin-bottom: 1rem;
      color: var(--text);
      border-bottom: 1px solid var(--border);
      padding-bottom: 0.5rem;
    }
    label {
      display: block;
      font-size: 0.85rem;
      font-weight: 500;
      margin-bottom: 0.35rem;
      color: var(--muted);
    }
    input,
    textarea {
      width: 100%;
      padding: 0.65rem 0.85rem;
      background: var(--bg);
      border: 1px solid var(--border);
      border-radius: 8px;
      color: var(--text);
      font-size: 0.95rem;
      margin-bottom: 1rem;
      font-family: inherit;
    }
    input:focus,
    textarea:focus {
      outline: none;
      border-color: var(--accent);
    }
    textarea {
      min-height: 100px;
      resize: vertical;
      font-family: 'Courier New', monospace;
      font-size: 0.85rem;
    }
    button {
      padding: 0.75rem 1rem;
      border: none;
      border-radius: 8px;
      font-size: 1rem;
      font-weight: 600;
      cursor: pointer;
      transition: all 0.2s;
    }
    button[type="submit"] {
      width: 100%;
      background: var(--accent);
      color: white;
      margin-top: 0.5rem;
    }
    button[type="submit"]:hover {
      background: var(--accent-hover);
    }
    .btn-secondary {
      background: var(--surface);
      border: 1px solid var(--border);
      color: var(--text);
      width: 100%;
      margin-top: 0.5rem;
    }
    .btn-secondary:hover {
      background: var(--border);
    }
    .btn-warning {
      background: var(--warning);
      color: white;
      width: 100%;
      margin-top: 0.5rem;
    }
    .btn-warning:hover {
      background: #d97706;
    }
    .alert {
      padding: 0.75rem 1rem;
      border-radius: 8px;
      margin-bottom: 1rem;
      font-size: 0.9rem;
    }
    .alert-success {
      background: rgba(34, 197, 94, 0.15);
      border: 1px solid var(--success);
      color: #4ade80;
    }
    .alert-error {
      background: rgba(239, 68, 68, 0.15);
      border: 1px solid var(--danger);
      color: #f87171;
    }
    .alert-info {
      background: rgba(59, 130, 246, 0.15);
      border: 1px solid var(--accent);
      color: #60a5fa;
    }
    .hint {
      font-size: 0.8rem;
      color: var(--muted);
      margin-top: -0.5rem;
      margin-bottom: 1rem;
    }
    code {
      background: rgba(255, 255, 255, 0.1);
      padding: 0.2rem 0.4rem;
      border-radius: 4px;
      font-size: 0.85em;
    }
    .section-divider {
      margin: 2rem 0;
      border-top: 1px solid var(--border);
    }
    .loading {
      display: none;
      text-align: center;
      padding: 1rem;
      color: var(--muted);
    }
    .loading.active {
      display: block;
    }
  </style>
</head>
<body>
  <div class="container">
    <h1>Configuration</h1>
    <p class="subtitle">Configure all settings. Frontend-saved values take priority over environment variables.</p>

    <% if (typeof success !== 'undefined' && success) { %>
      <div class="alert alert-success">
        ✓ Configuration saved successfully to <code>data/config.json</code>
      </div>
    <% } %>

    <% if (typeof error !== 'undefined' && error) { %>
      <div class="alert alert-error">
        ✗ <%= error %>
      </div>
    <% } %>

    <% if (typeof tokenGenerated !== 'undefined' && tokenGenerated) { %>
      <div class="alert alert-success">
        ✓ Token generated successfully! Refresh token saved to <code>data/config.json</code>
      </div>
    <% } %>

    <% if (typeof tokenError !== 'undefined' && tokenError) { %>
      <div class="alert alert-error">
        ✗ Token generation failed: <%= tokenError %>
      </div>
    <% } %>

    <form method="POST" action="/credentials" id="configForm">
      <!-- Google OAuth Credentials -->
      <div class="card">
        <h2>Google OAuth Credentials</h2>
        
        <label for="GOOGLE_CREDENTIALS_JSON">GOOGLE_CREDENTIALS_JSON *</label>
        <textarea
          id="GOOGLE_CREDENTIALS_JSON"
          name="GOOGLE_CREDENTIALS_JSON"
          placeholder='{"web":{"client_id":"...","client_secret":"...","redirect_uris":["..."]}}'
        ><%= GOOGLE_CREDENTIALS_JSON || '' %></textarea>
        <p class="hint">Full JSON credentials object from Google Cloud Console (or use GOOGLE_CREDENTIALS_PATH below)</p>

        <label for="GOOGLE_CREDENTIALS_PATH">GOOGLE_CREDENTIALS_PATH</label>
        <input
          type="text"
          id="GOOGLE_CREDENTIALS_PATH"
          name="GOOGLE_CREDENTIALS_PATH"
          value="<%= GOOGLE_CREDENTIALS_PATH || '' %>"
          placeholder="credentials.json"
        />
        <p class="hint">Path to credentials JSON file (relative to project root). Used if GOOGLE_CREDENTIALS_JSON is empty.</p>

        <label for="GOOGLE_TOKEN_JSON">GOOGLE_TOKEN_JSON</label>
        <textarea
          id="GOOGLE_TOKEN_JSON"
          name="GOOGLE_TOKEN_JSON"
          placeholder='{"access_token":"...","refresh_token":"...","scope":"...","token_type":"Bearer","expiry_date":...}'
        ><%= GOOGLE_TOKEN_JSON || '' %></textarea>
        <p class="hint">OAuth token JSON (access_token, refresh_token, etc.). Leave empty to generate via button below.</p>

        <button type="button" class="btn-warning" onclick="generateToken()">Generate OAuth Token</button>
        <div class="loading" id="tokenLoading">Generating token... Please wait...</div>
      </div>

      <!-- Google Calendar Settings -->
      <div class="card">
        <h2>Google Calendar Settings</h2>
        
        <label for="GOOGLE_CALENDAR_ID">GOOGLE_CALENDAR_ID</label>
        <input
          type="text"
          id="GOOGLE_CALENDAR_ID"
          name="GOOGLE_CALENDAR_ID"
          value="<%= GOOGLE_CALENDAR_ID || 'primary' %>"
          placeholder="primary"
        />
        <p class="hint">Calendar ID to sync (default: "primary")</p>

        <label for="CALENDAR_POLL_MINUTES">CALENDAR_POLL_MINUTES</label>
        <input
          type="number"
          id="CALENDAR_POLL_MINUTES"
          name="CALENDAR_POLL_MINUTES"
          value="<%= CALENDAR_POLL_MINUTES || '' %>"
          placeholder="5"
          min="0"
        />
        <p class="hint">Polling interval in minutes (0 = disabled, use webhooks instead)</p>
      </div>

      <!-- LimoExpress API Settings -->
      <div class="card">
        <h2>LimoExpress API Settings</h2>
        
        <label for="LIMOEXPRESS_API_URL">LIMOEXPRESS_API_URL *</label>
        <input
          type="url"
          id="LIMOEXPRESS_API_URL"
          name="LIMOEXPRESS_API_URL"
          value="<%= LIMOEXPRESS_API_URL || '' %>"
          placeholder="https://api.limoexpress.app"
          required
        />
        <p class="hint">Base URL for LimoExpress API</p>

        <label for="LIMOEXPRESS_API_KEY">LIMOEXPRESS_API_KEY *</label>
        <input
          type="password"
          id="LIMOEXPRESS_API_KEY"
          name="LIMOEXPRESS_API_KEY"
          value="<%= LIMOEXPRESS_API_KEY ? '••••••••' : '' %>"
          placeholder="Your API key"
          autocomplete="new-password"
        />
        <p class="hint">Bearer token for LimoExpress API authentication</p>

        <label for="LIMOEXPRESS_BOOKING_TYPE_ID">LIMOEXPRESS_BOOKING_TYPE_ID</label>
        <input
          type="text"
          id="LIMOEXPRESS_BOOKING_TYPE_ID"
          name="LIMOEXPRESS_BOOKING_TYPE_ID"
          value="<%= LIMOEXPRESS_BOOKING_TYPE_ID || '' %>"
          placeholder="e.g., 1"
        />
        <p class="hint">Booking type ID from LimoExpress API (get from GET /api/integration/booking-types)</p>
      </div>

      <div class="card">
        <button type="submit">Save Configuration</button>
        <div class="alert alert-info" style="margin-top: 1rem; margin-bottom: 0;">
          <strong>Note:</strong> Frontend-saved values override environment variables. Leave fields empty to use .env values.
        </div>
      </div>
    </form>
  </div>

  <script>
    async function generateToken() {
      const loadingEl = document.getElementById('tokenLoading');
      const credentialsJson = document.getElementById('GOOGLE_CREDENTIALS_JSON').value.trim();
      const credentialsPath = document.getElementById('GOOGLE_CREDENTIALS_PATH').value.trim();

      if (!credentialsJson && !credentialsPath) {
        alert('Please provide either GOOGLE_CREDENTIALS_JSON or GOOGLE_CREDENTIALS_PATH first.');
        return;
      }

      loadingEl.classList.add('active');
      loadingEl.textContent = 'Generating token... Please wait...';
      
      try {
        const response = await fetch('/auth/generate-token', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
          },
          body: JSON.stringify({
            GOOGLE_CREDENTIALS_JSON: credentialsJson || null,
            GOOGLE_CREDENTIALS_PATH: credentialsPath || null,
          }),
        });

        const result = await response.json();
        
        if (result.success && result.authUrl) {
          loadingEl.textContent = 'Opening authorization page... Complete the authorization and return here.';
          // Open auth URL in new window
          window.open(result.authUrl, '_blank');
          // Poll for token completion
          checkTokenCompletion();
        } else {
          alert('Token generation failed: ' + (result.error || result.message || 'Unknown error'));
          loadingEl.classList.remove('active');
        }
      } catch (error) {
        alert('Error: ' + error.message);
        loadingEl.classList.remove('active');
      }
    }

    function checkTokenCompletion() {
      const loadingEl = document.getElementById('tokenLoading');
      const checkInterval = setInterval(async () => {
        try {
          // Reload config to check if token was saved
          const response = await fetch('/credentials');
          const text = await response.text();
          if (text.includes('tokenGenerated=1') || text.includes('GOOGLE_TOKEN_JSON')) {
            clearInterval(checkInterval);
            loadingEl.classList.remove('active');
            window.location.href = '/credentials?tokenGenerated=1';
          }
        } catch (err) {
          // Ignore errors, keep polling
        }
      }, 2000);

      // Stop polling after 5 minutes
      setTimeout(() => {
        clearInterval(checkInterval);
        loadingEl.classList.remove('active');
        loadingEl.textContent = 'Token generation timeout. Please try again or check manually.';
      }, 300000);
    }
  </script>
</body>
</html>
