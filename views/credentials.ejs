<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <style>
    :root {
      --bg: #0f1419;
      --surface: #1a2332;
      --border: #2d3a4d;
      --text: #e6edf3;
      --muted: #8b949e;
      --accent: #3b82f6;
      --accent-hover: #2563eb;
      --success: #22c55e;
      --danger: #ef4444;
    }
    * {
      box-sizing: border-box;
    }
    body {
      font-family: 'Segoe UI', system-ui, -apple-system, sans-serif;
      background: var(--bg);
      color: var(--text);
      margin: 0;
      min-height: 100vh;
      line-height: 1.5;
    }
    .container {
      max-width: 560px;
      margin: 0 auto;
      padding: 2rem 1.5rem;
    }
    h1 {
      font-size: 1.5rem;
      font-weight: 600;
      margin-bottom: 0.5rem;
    }
    .subtitle {
      color: var(--muted);
      font-size: 0.9rem;
      margin-bottom: 1.5rem;
    }
    .card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 12px;
      padding: 1.5rem;
    }
    label {
      display: block;
      font-size: 0.85rem;
      font-weight: 500;
      margin-bottom: 0.35rem;
      color: var(--muted);
    }
    input,
    textarea {
      width: 100%;
      padding: 0.65rem 0.85rem;
      background: var(--bg);
      border: 1px solid var(--border);
      border-radius: 8px;
      color: var(--text);
      font-size: 0.95rem;
      margin-bottom: 1rem;
      font-family: inherit;
    }
    input:focus,
    textarea:focus {
      outline: none;
      border-color: var(--accent);
    }
    textarea {
      min-height: 80px;
      resize: vertical;
    }
    button[type="submit"] {
      width: 100%;
      padding: 0.75rem 1rem;
      background: var(--accent);
      color: white;
      border: none;
      border-radius: 8px;
      font-size: 1rem;
      font-weight: 600;
      cursor: pointer;
      margin-top: 0.5rem;
      transition: background 0.2s;
    }
    button[type="submit"]:hover {
      background: var(--accent-hover);
    }
    .alert {
      padding: 0.75rem 1rem;
      border-radius: 8px;
      margin-bottom: 1rem;
      font-size: 0.9rem;
    }
    .alert-success {
      background: rgba(34, 197, 94, 0.15);
      border: 1px solid var(--success);
      color: #4ade80;
    }
    .alert-error {
      background: rgba(239, 68, 68, 0.15);
      border: 1px solid var(--danger);
      color: #f87171;
    }
    .hint {
      font-size: 0.8rem;
      color: var(--muted);
      margin-top: -0.5rem;
      margin-bottom: 1rem;
    }
    code {
      background: rgba(255, 255, 255, 0.1);
      padding: 0.2rem 0.4rem;
      border-radius: 4px;
      font-size: 0.85em;
    }
  </style>
</head>
<body>
  <div class="container">
    <h1>Save Credentials</h1>
    <p class="subtitle">Store OAuth client ID and secret locally (saved to <code>data/credentials.json</code>)</p>

    <% if (typeof success !== 'undefined' && success) { %>
      <div class="alert alert-success">
        ✓ Credentials saved successfully to <code>data/credentials.json</code>
      </div>
    <% } %>

    <% if (typeof error !== 'undefined' && error) { %>
      <div class="alert alert-error">
        ✗ <%= error %>
      </div>
    <% } %>

    <div class="card">
      <form method="POST" action="/credentials">
        <label for="client_id">Client ID *</label>
        <input
          type="text"
          id="client_id"
          name="client_id"
          value="<%= client_id %>"
          required
          autocomplete="off"
          placeholder="e.g., 123456789-abc123.apps.googleusercontent.com"
        />

        <label for="client_secret">Client Secret *</label>
        <input
          type="password"
          id="client_secret"
          name="client_secret"
          value=""
          placeholder="<%= hasSecret ? 'Leave blank to keep existing secret' : 'Enter your client secret' %>"
          autocomplete="new-password"
          <%= !hasSecret ? 'required' : '' %>
        />
        <% if (hasSecret) { %>
          <p class="hint">A secret is already saved. Leave blank to keep it, or enter a new one to update.</p>
        <% } %>

        <label for="redirect_uris">Redirect URIs (optional)</label>
        <textarea
          id="redirect_uris"
          name="redirect_uris"
          placeholder="http://localhost:3000/oauth2callback&#10;https://yourdomain.com/oauth2callback"
        ><%= redirect_uris %></textarea>
        <p class="hint">Enter one URI per line, or separate with commas</p>

        <button type="submit">Save Credentials</button>
      </form>
    </div>
  </div>
</body>
</html>
