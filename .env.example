PORT=3000

# Google Calendar (required for automation)
# Option A: JSON strings in .env (use single quotes so double quotes inside are fine)
# GOOGLE_CREDENTIALS_JSON='{"web":{"client_id":"...","project_id":"...","auth_uri":"...","token_uri":"...","auth_provider_x509_cert_url":"...","client_secret":"..."}}'
# GOOGLE_TOKEN_JSON='{"access_token":"...","refresh_token":"...","scope":"...","token_type":"Bearer","expiry_date":...}'
# Option B: Path to OAuth2 credentials JSON file (if above not set)
GOOGLE_CREDENTIALS_PATH=credentials.json
# Calendar ID to watch (use "primary" for main calendar)
GOOGLE_CALENDAR_ID=primary
# Optional: base URL for webhook (must be HTTPS for Google). Use ngrok for local dev, e.g. https://abc123.ngrok.io
WEBHOOK_BASE_URL=

# LimoExpress (required for creating bookings)
# API base URL and key - get from LimoExpress advanced settings
LIMOEXPRESS_API_URL=https://api.limoexpress.app
LIMOEXPRESS_API_KEY=
# Required: booking type UUID from GET /api/integration/booking-types
LIMOEXPRESS_BOOKING_TYPE_ID=
# Optional: only sync events whose description contains this phrase (case-insensitive). Empty = sync all. Default: "Added to Limo: yes"
# LIMO_SYNC_REQUIRE_FLAG=Added to Limo: yes

# Optional: poll calendar every N minutes if webhook not used (set to 0 to disable)
CALENDAR_POLL_MINUTES=0
